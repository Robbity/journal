<h1 class="text-center mt-5">All Entries</h1>
<div>
  <table class="table">
    <thead>
      <tr>
        <th> Name </th>
        <th> Link </th>
      </tr>
    </thead>
  <tbody>
    <% @entries.each do |entry| %>
      <tr>
        <td> <%= entry.name %> </td>
        <td> <%= link_to "Visit Link", entry.link, target: "_blank" %> </td>  
        <td>
          <%= button_to "Delete", entry, method: :delete, data: { confirm: "Are you sure you want to delete this Project ?"} %> 
        </td>
      </tr>
    <% end %>
  </tbody>
 </table>
</div>